{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://v4/schemas/skills/pdf-intake-packetization.output.schema.json",
  "title": "V4 PDF Intake Packetization Skill Output (Governed Provisional)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_instance_id",
    "source_document_id",
    "provisional_status",
    "review_gated",
    "hard_guardrail_confirmation",
    "sheet_classifications",
    "possible_relationships",
    "source_artifact_register",
    "manual_confirmation_flags",
    "trace_refs"
  ],
  "properties": {
    "project_instance_id": {
      "type": "string",
      "minLength": 1
    },
    "source_document_id": {
      "type": "string",
      "minLength": 1
    },
    "provisional_status": {
      "type": "string",
      "const": "provisional_pending_manual_review"
    },
    "review_gated": {
      "type": "boolean",
      "const": true
    },
    "hard_guardrail_confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quantities_extracted",
        "takeoff_items_created",
        "cost_outputs_created",
        "pricing_records_created",
        "production_rate_records_created",
        "review_gated"
      ],
      "properties": {
        "quantities_extracted": { "type": "boolean", "const": false },
        "takeoff_items_created": { "type": "boolean", "const": false },
        "cost_outputs_created": { "type": "boolean", "const": false },
        "pricing_records_created": { "type": "boolean", "const": false },
        "production_rate_records_created": { "type": "boolean", "const": false },
        "review_gated": { "type": "boolean", "const": true }
      }
    },
    "sheet_classifications": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sheet_id",
          "sheet_title",
          "sheet_class",
          "confidence",
          "provisional_status",
          "trace_refs"
        ],
        "properties": {
          "sheet_id": { "type": "string", "minLength": 1 },
          "sheet_title": { "type": "string", "minLength": 1 },
          "sheet_class": {
            "type": "string",
            "enum": ["cover", "plan", "profile", "detail", "index", "unknown"]
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "provisional_status": { "type": "string", "const": "provisional" },
          "trace_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "possible_relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relationship_id",
          "relationship_type",
          "from_sheet_id",
          "to_sheet_id",
          "confidence",
          "provisional_status",
          "trace_refs"
        ],
        "properties": {
          "relationship_id": { "type": "string", "minLength": 1 },
          "relationship_type": {
            "type": "string",
            "enum": ["references", "depends_on", "see_also", "sheet_sequence"]
          },
          "from_sheet_id": { "type": "string", "minLength": 1 },
          "to_sheet_id": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "provisional_status": { "type": "string", "const": "provisional" },
          "trace_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "source_artifact_register": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "artifact_type",
          "source_document_id",
          "storage_ref",
          "page_range",
          "provisional_status",
          "trace_refs"
        ],
        "properties": {
          "artifact_id": { "type": "string", "minLength": 1 },
          "artifact_type": {
            "type": "string",
            "enum": ["sheet_index_capture", "sheet_snippet", "legend_capture", "notes_capture"]
          },
          "source_document_id": { "type": "string", "minLength": 1 },
          "storage_ref": { "type": "string", "minLength": 1 },
          "page_range": {
            "type": "object",
            "additionalProperties": false,
            "required": ["start_page", "end_page"],
            "properties": {
              "start_page": { "type": "integer", "minimum": 1 },
              "end_page": { "type": "integer", "minimum": 1 }
            }
          },
          "provisional_status": { "type": "string", "const": "provisional" },
          "trace_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "manual_confirmation_flags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["flag_code", "required", "reason", "trace_refs"],
        "properties": {
          "flag_code": {
            "type": "string",
            "enum": [
              "missing_plan_index",
              "duplicate_sheet_ids",
              "mixed_utility_sheets",
              "broad_construction_detail_sheets",
              "low_confidence_classifications"
            ]
          },
          "required": { "type": "boolean", "const": true },
          "reason": { "type": "string", "minLength": 1 },
          "trace_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "trace_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
