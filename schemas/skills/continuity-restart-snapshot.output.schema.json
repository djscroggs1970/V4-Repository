{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://v4-framework.local/schemas/skills/continuity-restart-snapshot.output.schema.json",
  "title": "V4 Continuity / Restart Snapshot Skill Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill_name",
    "session_mode",
    "outcome",
    "confidence",
    "current_verified_version",
    "latest_verified_checkpoint",
    "latest_merged_pr",
    "latest_ci_run_id",
    "latest_ci_status",
    "latest_ci_conclusion",
    "merge_sha",
    "airtable_checkpoint_record_id",
    "continuity_pr_status",
    "active_branch",
    "active_pr",
    "active_implementation_slice",
    "active_skill_lane",
    "source_of_truth_review",
    "verified_context",
    "provisional_context",
    "guardrail_review",
    "manual_confirmation_required",
    "manual_confirmation_reasons",
    "job_project_data_detected",
    "pdf_plan_data_detected",
    "quantity_or_cost_output_detected",
    "external_write_attempt_detected",
    "stale_or_conflicting_claims",
    "snapshot_quality",
    "recommended_next_action",
    "safe_new_chat_handoff_prompt",
    "current_state_update_recommendation",
    "trace_refs"
  ],
  "properties": {
    "skill_name": { "const": "V4 Continuity / Restart Snapshot Skill" },
    "session_mode": { "type": "string", "enum": ["implementation", "skill_design", "verification_only", "continuity_only"] },
    "outcome": { "type": "string", "enum": ["restart_snapshot_ready", "needs_source_of_truth_check", "blocked_unverified_claim", "manual_confirmation_required", "continuity_update_candidate", "stale_or_conflicting_context", "handoff_ready"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "current_verified_version": { "type": "string", "minLength": 1 },
    "latest_verified_checkpoint": { "type": "string", "minLength": 1 },
    "latest_merged_pr": { "oneOf": [{ "type": "integer", "minimum": 1 }, { "type": "string", "minLength": 1 }] },
    "latest_ci_run_id": { "oneOf": [{ "type": "integer", "minimum": 1 }, { "type": "string", "minLength": 1 }] },
    "latest_ci_status": { "type": "string", "enum": ["queued", "in_progress", "completed", "missing", "unknown"] },
    "latest_ci_conclusion": { "type": "string", "enum": ["success", "failure", "cancelled", "skipped", "timed_out", "action_required", "pending", "missing", "unknown"] },
    "merge_sha": { "type": "string", "minLength": 1 },
    "airtable_checkpoint_record_id": { "type": "string", "minLength": 1 },
    "continuity_pr_status": { "type": "string", "enum": ["not_applicable", "open_unverified", "open_ci_pending", "merged_uncheckpointed", "merged_checkpointed", "unknown"] },
    "active_branch": { "type": "string", "minLength": 1 },
    "active_pr": { "type": "string", "minLength": 1 },
    "active_implementation_slice": { "type": "string", "minLength": 1 },
    "active_skill_lane": { "type": "string", "minLength": 1 },
    "source_of_truth_review": { "$ref": "#/$defs/source_review" },
    "verified_context": { "type": "array", "items": { "type": "string" } },
    "provisional_context": { "type": "array", "items": { "type": "string" } },
    "guardrail_review": { "$ref": "#/$defs/guardrail_review" },
    "manual_confirmation_required": { "type": "boolean" },
    "manual_confirmation_reasons": { "type": "array", "items": { "type": "string" } },
    "job_project_data_detected": { "type": "boolean" },
    "pdf_plan_data_detected": { "type": "boolean" },
    "quantity_or_cost_output_detected": { "type": "boolean" },
    "external_write_attempt_detected": { "type": "boolean" },
    "stale_or_conflicting_claims": { "type": "array", "items": { "type": "string" } },
    "snapshot_quality": { "type": "string", "enum": ["compact", "oversized", "vague", "conflicting"] },
    "recommended_next_action": { "type": "string", "minLength": 1 },
    "safe_new_chat_handoff_prompt": { "type": "string", "minLength": 1 },
    "current_state_update_recommendation": { "type": "string", "enum": ["not_authorized", "candidate_only", "needs_evidence_refresh"] },
    "trace_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  },
  "$defs": {
    "evidence_status": { "type": "string", "enum": ["present_confirmed", "present_unconfirmed", "missing", "conflicting", "not_applicable"] },
    "source_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["github", "airtable", "google_drive", "clickup", "chat_history", "current_state_md"],
      "properties": {
        "github": { "$ref": "#/$defs/evidence_status" },
        "airtable": { "$ref": "#/$defs/evidence_status" },
        "google_drive": { "$ref": "#/$defs/evidence_status" },
        "clickup": { "$ref": "#/$defs/evidence_status" },
        "chat_history": { "$ref": "#/$defs/evidence_status" },
        "current_state_md": { "$ref": "#/$defs/evidence_status" }
      }
    },
    "guardrail_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["no_runtime_external_writes", "no_merge_or_checkpoint_authority", "no_current_state_update_authority", "no_pdf_intelligence", "no_real_job_data", "no_quantity_cost_rate_outputs", "instance_and_document_isolation_preserved", "framework_job_data_separation_preserved", "compact_restart_focus", "review_gated_status"],
      "properties": {
        "no_runtime_external_writes": { "type": "boolean" },
        "no_merge_or_checkpoint_authority": { "type": "boolean" },
        "no_current_state_update_authority": { "type": "boolean" },
        "no_pdf_intelligence": { "type": "boolean" },
        "no_real_job_data": { "type": "boolean" },
        "no_quantity_cost_rate_outputs": { "type": "boolean" },
        "instance_and_document_isolation_preserved": { "type": "boolean" },
        "framework_job_data_separation_preserved": { "type": "boolean" },
        "compact_restart_focus": { "type": "boolean" },
        "review_gated_status": { "type": "string", "enum": ["preserved", "missing"] }
      }
    }
  }
}
