{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://v4-framework.local/schemas/skills/pr-review-merge-gate.output.schema.json",
  "title": "V4 PR Review / Merge Gate Skill Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill_name",
    "pr_number",
    "pr_title",
    "branch",
    "base_branch",
    "head_sha",
    "mergeable",
    "draft",
    "claimed_scope",
    "changed_files",
    "ci_run_id",
    "ci_status",
    "ci_conclusion",
    "ci_required_steps",
    "ci_all_required_steps_passed",
    "scope_alignment",
    "guardrail_compliance",
    "drift_risk",
    "real_job_data_detected",
    "pdf_intelligence_detected",
    "unauthorized_quantity_or_cost_output_detected",
    "unauthorized_current_state_update_detected",
    "unauthorized_airtable_governance_detected",
    "provisional_review_gated_status",
    "traceability_status",
    "decision",
    "confidence",
    "manual_confirmation_required",
    "manual_confirmation_reasons",
    "required_actions",
    "merge_recommendation",
    "checkpoint_recommendation",
    "continuity_update_recommendation",
    "handoff_note",
    "trace_refs"
  ],
  "properties": {
    "skill_name": { "const": "V4 PR Review / Merge Gate Skill" },
    "pr_number": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "string", "const": "unknown" }
      ]
    },
    "pr_title": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "base_branch": { "type": "string", "minLength": 1 },
    "head_sha": { "type": "string", "minLength": 1 },
    "mergeable": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "string", "const": "unknown" }
      ]
    },
    "draft": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "string", "const": "unknown" }
      ]
    },
    "claimed_scope": { "type": "string", "minLength": 1 },
    "changed_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "change_type", "additions", "deletions", "review_category", "scope_status", "notes"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "change_type": { "type": "string", "enum": ["added", "modified", "deleted", "renamed", "unknown"] },
          "additions": {
            "oneOf": [
              { "type": "integer", "minimum": 0 },
              { "type": "string", "const": "unknown" }
            ]
          },
          "deletions": {
            "oneOf": [
              { "type": "integer", "minimum": 0 },
              { "type": "string", "const": "unknown" }
            ]
          },
          "review_category": {
            "type": "string",
            "enum": [
              "source_code",
              "test",
              "schema",
              "docs",
              "continuity_docs",
              "skill_docs",
              "governance_fixture",
              "ci_workflow",
              "package_export",
              "airtable_governance",
              "project_data",
              "unknown"
            ]
          },
          "scope_status": { "type": "string", "enum": ["in_scope", "out_of_scope", "ambiguous"] },
          "notes": { "type": "string" }
        }
      }
    },
    "ci_run_id": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "string", "const": "unknown" }
      ]
    },
    "ci_status": { "type": "string", "enum": ["queued", "in_progress", "completed", "missing", "unknown"] },
    "ci_conclusion": { "type": "string", "enum": ["success", "failure", "cancelled", "skipped", "timed_out", "action_required", "pending", "missing", "unknown"] },
    "ci_required_steps": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "prefixItems": [
        { "$ref": "#/$defs/ci_step_install" },
        { "$ref": "#/$defs/ci_step_build" },
        { "$ref": "#/$defs/ci_step_typecheck" },
        { "$ref": "#/$defs/ci_step_test" },
        { "$ref": "#/$defs/ci_step_validate_rules" },
        { "$ref": "#/$defs/ci_step_sample_vs1a" },
        { "$ref": "#/$defs/ci_step_sample_vs1a_upload" }
      ]
    },
    "ci_all_required_steps_passed": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "string", "const": "unknown" }
      ]
    },
    "scope_alignment": { "type": "string", "enum": ["aligned", "minor_uncertainty", "misaligned", "unknown"] },
    "guardrail_compliance": { "type": "string", "enum": ["compliant", "needs_review", "violation", "unknown"] },
    "drift_risk": { "type": "string", "enum": ["low", "medium", "high", "unknown"] },
    "real_job_data_detected": { "type": "boolean" },
    "pdf_intelligence_detected": { "type": "boolean" },
    "unauthorized_quantity_or_cost_output_detected": { "type": "boolean" },
    "unauthorized_current_state_update_detected": { "type": "boolean" },
    "unauthorized_airtable_governance_detected": { "type": "boolean" },
    "provisional_review_gated_status": { "type": "string", "enum": ["preserved", "missing", "not_applicable", "unknown"] },
    "traceability_status": { "type": "string", "enum": ["adequate", "missing", "not_applicable", "unknown"] },
    "decision": {
      "type": "string",
      "enum": [
        "ready_to_merge",
        "blocked_failed_ci",
        "blocked_scope_drift",
        "blocked_guardrail_violation",
        "needs_manual_review",
        "docs_only_ready",
        "checkpoint_ready_after_merge",
        "not_checkpoint_eligible"
      ]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "manual_confirmation_required": { "type": "boolean" },
    "manual_confirmation_reasons": { "type": "array", "items": { "type": "string" } },
    "required_actions": { "type": "array", "items": { "type": "string" } },
    "merge_recommendation": {
      "type": "string",
      "enum": ["recommend_merge", "do_not_merge", "hold_for_manual_review", "report_only_no_merge_recommendation"]
    },
    "checkpoint_recommendation": {
      "type": "string",
      "enum": ["checkpoint_after_merge", "do_not_checkpoint", "checkpoint_needs_merge_sha_and_airtable_record", "not_applicable"]
    },
    "continuity_update_recommendation": {
      "type": "string",
      "enum": ["create_continuity_update_pr_after_checkpoint", "continuity_update_ready", "do_not_update_current_state_yet", "not_applicable"]
    },
    "handoff_note": { "type": "string", "minLength": 1 },
    "trace_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  },
  "$defs": {
    "ci_step_base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "required", "status", "conclusion", "evidence"],
      "properties": {
        "name": { "type": "string" },
        "required": { "const": true },
        "status": { "type": "string", "enum": ["passed", "failed", "pending", "missing", "skipped", "unknown"] },
        "conclusion": { "type": "string", "enum": ["success", "failure", "pending", "missing", "skipped", "unknown"] },
        "evidence": { "type": "string" }
      }
    },
    "ci_step_install": { "allOf": [{ "$ref": "#/$defs/ci_step_base" }, { "properties": { "name": { "const": "pnpm install --frozen-lockfile=false" } } }] },
    "ci_step_build": { "allOf": [{ "$ref": "#/$defs/ci_step_base" }, { "properties": { "name": { "const": "pnpm build" } } }] },
    "ci_step_typecheck": { "allOf": [{ "$ref": "#/$defs/ci_step_base" }, { "properties": { "name": { "const": "pnpm typecheck" } } }] },
    "ci_step_test": { "allOf": [{ "$ref": "#/$defs/ci_step_base" }, { "properties": { "name": { "const": "pnpm test" } } }] },
    "ci_step_validate_rules": { "allOf": [{ "$ref": "#/$defs/ci_step_base" }, { "properties": { "name": { "const": "pnpm validate:rules" } } }] },
    "ci_step_sample_vs1a": { "allOf": [{ "$ref": "#/$defs/ci_step_base" }, { "properties": { "name": { "const": "pnpm sample:vs1a" } } }] },
    "ci_step_sample_vs1a_upload": { "allOf": [{ "$ref": "#/$defs/ci_step_base" }, { "properties": { "name": { "const": "pnpm sample:vs1a:upload" } } }] }
  }
}
